{
  "name": "arena-dos-mestres",
  "version": "1.0.0",
  "type": "module",
  "description": "Jogo educativo de matemática para alunos do 7° ano SESI — 11/12 anos",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
    "build": "npm run build --workspace=client",
    "install:all": "npm install && npm install --workspace=client && npm install --workspace=server",
    "setup": "node server/db/init.js",
    "start": "npm run dev"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "vite": "^8.0.14"
  }
}
